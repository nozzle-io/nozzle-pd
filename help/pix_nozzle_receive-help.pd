#N canvas 90 90 780 580 10;
#X obj 40 40 declare -lib Gem;
#X obj 40 105 gemhead;
#X obj 40 140 pix_nozzle_receive nozzle_pd_cpu_demo;
#X obj 40 175 pix_texture;
#X obj 40 210 rectangle 4 3;
#X msg 325 145 name nozzle_pd_cpu_demo;
#X obj 40 290 gemwin;
#X msg 40 255 create \, 1;
#X msg 135 255 0 \, destroy;
#X text 40 15 pix_nozzle_receive - receive nozzle frames and inject them into a GEM pix chain.;
#X text 40 335 Creation: [pix_nozzle_receive <sender-name>] connects to a nozzle sender. If omitted the sender name defaults to nozzle_sender.;
#X text 40 370 Inlet: GEM render-chain trigger from [gemhead]. Outlet: GEM pixBlock containing the latest received frame for [pix_texture].;
#X text 40 405 Smoke test: run pix_nozzle_send-help.pd or another nozzle sender named nozzle_pd_cpu_demo \, then open the GEM window here.;
#X text 40 455 Message: [name <symbol>( changes the receiver target and reconnects on the next render pass.;
#X text 40 490 Notes: receive mode is latest-only and timeout is non-blocking. If no frame is available the object leaves the previous GEM state unchanged.;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 5 0 2 0;
#X connect 7 0 6 0;
#X connect 8 0 6 0;
