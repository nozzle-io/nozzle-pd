#N canvas 90 90 800 600 10;
#X obj 40 40 declare -lib Gem;
#X obj 40 105 gemhead;
#X obj 40 140 pix_video;
#X obj 40 175 pix_texture;
#X obj 40 210 pix_nozzle_gl_send nozzle_pd_gl_demo;
#X obj 40 245 rectangle 4 3;
#X msg 330 180 name nozzle_pd_gl_demo;
#X obj 40 325 gemwin;
#X msg 40 290 create \, 1;
#X msg 135 290 0 \, destroy;
#X text 40 15 pix_nozzle_gl_send - publish the currently bound OpenGL texture through nozzle.;
#X text 40 370 Creation: [pix_nozzle_gl_send <sender-name>] creates or reuses a nozzle sender. If omitted the sender name defaults to nozzle_sender.;
#X text 40 405 Inlet: GEM render chain after an upstream object such as [pix_texture] has bound GL_TEXTURE_2D. Outlet: normal GEM chain continuation.;
#X text 40 440 Smoke test: run this patch and pix_nozzle_gl_receive-help.pd with the same name nozzle_pd_gl_demo.;
#X text 40 490 Message: [name <symbol>( changes the sender name and recreates the sender on the next publish.;
#X text 40 525 Notes: this is the GPU/OpenGL path. A valid OpenGL context and a bound 2D texture are required; otherwise no frame is published.;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 6 0 4 0;
#X connect 8 0 7 0;
#X connect 9 0 7 0;
