#N canvas 90 90 760 560 10;
#X obj 40 40 declare -lib Gem;
#X obj 40 105 gemhead;
#X obj 40 140 pix_video;
#X obj 40 175 pix_nozzle_send nozzle_pd_cpu_demo;
#X msg 300 145 name nozzle_pd_cpu_demo;
#X obj 40 255 gemwin;
#X msg 40 220 create \, 1;
#X msg 135 220 0 \, destroy;
#X text 40 15 pix_nozzle_send - send GEM pix image data through nozzle using the CPU copy path.;
#X text 40 305 Creation: [pix_nozzle_send <sender-name>] creates or reuses a nozzle sender. If omitted the sender name defaults to nozzle_sender.;
#X text 40 340 Inlet: GEM pix chain input from objects such as [pix_video] or [pix_image]. Outlet: normal GEM chain outlet inherited from GemPixObj.;
#X text 40 375 Smoke test: open the GEM window \, start a camera/source \, then open pix_nozzle_receive-help.pd with the same name nozzle_pd_cpu_demo.;
#X text 40 425 Message: [name <symbol>( changes the sender name and recreates the sender on the next frame.;
#X text 40 460 Notes: this path copies pixel data into nozzle-owned shared storage. Use pix_nozzle_gl_send when you need the OpenGL texture path.;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 4 0 3 0;
#X connect 6 0 5 0;
#X connect 7 0 5 0;
